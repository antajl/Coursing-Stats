# Disable caching for HTML to ensure users always get the latest version
/index.html
  Cache-Control: no-cache, no-store, must-revalidate
  Pragma: no-cache
  Expires: 0

# Hashed build assets — long cache only when the real file exists.
# Do NOT rely on this for missing files: _redirects must 404 /assets/* (not SPA HTML),
# otherwise HTML can be cached as immutable under a .js URL and white-screen the site.
/assets/*
  Cache-Control: public, max-age=31536000, immutable
  X-Content-Type-Options: nosniff

# Long-term caching for static images and fonts in public/
/*.svg
  Cache-Control: public, max-age=31536000, immutable
/*.png
  Cache-Control: public, max-age=31536000, immutable
/*.jpg
  Cache-Control: public, max-age=31536000, immutable
/*.jpeg
  Cache-Control: public, max-age=31536000, immutable
/*.webp
  Cache-Control: public, max-age=31536000, immutable
/*.ico
  Cache-Control: public, max-age=31536000, immutable
/*.woff
  Cache-Control: public, max-age=31536000, immutable
/*.woff2
  Cache-Control: public, max-age=31536000, immutable

# Revalidate data files periodically (not immutable, but cached)
/data/*
  Cache-Control: public, max-age=3600, must-revalidate

# CSP for iframe embedding
/*
  Content-Security-Policy: frame-ancestors 'self' http://procoursing.ru https://procoursing.ru http://www.procoursing.ru https://www.procoursing.ru

# HSTS - Force HTTPS for 1 year, include subdomains
/*
  Strict-Transport-Security: max-age=31536000; includeSubDomains
