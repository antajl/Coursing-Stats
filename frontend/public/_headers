# Hashed build assets. Короткий/нулевой max-age: иначе при гонке деплоя SPA
# отдаёт index.html на /assets/*.js с заголовками assets → браузер кэширует HTML
# как «JS» и белый экран до hard refresh. Имена с [hash]/stamp всё равно уникальны.
/assets/*
  Cache-Control: no-cache, must-revalidate
  X-Content-Type-Options: nosniff

# Long-term caching for static images and fonts in public/
/*.svg
  Cache-Control: public, max-age=31536000, immutable
/*.png
  Cache-Control: public, max-age=31536000, immutable
/*.jpg
  Cache-Control: public, max-age=31536000, immutable
/*.jpeg
  Cache-Control: public, max-age=31536000, immutable
/*.webp
  Cache-Control: public, max-age=31536000, immutable
/*.ico
  Cache-Control: public, max-age=31536000, immutable
/*.woff
  Cache-Control: public, max-age=31536000, immutable
/*.woff2
  Cache-Control: public, max-age=31536000, immutable

# Revalidate data files periodically (not immutable, but cached)
/data/*
  Cache-Control: public, max-age=3600, must-revalidate

# CSP for iframe embedding
/*
  Content-Security-Policy: frame-ancestors 'self' http://procoursing.ru https://procoursing.ru http://www.procoursing.ru https://www.procoursing.ru

# HSTS - Force HTTPS for 1 year, include subdomains
/*
  Strict-Transport-Security: max-age=31536000; includeSubDomains
