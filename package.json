{
  "name": "procoursing-stats-scraper",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npx wrangler dev backend/src/worker.js --port 8787\" \"cd frontend && npm run dev\"",
    "scrape-index": "node backend/scripts/scrape-year-index.mjs",
    "parse-coursing": "node backend/parsers/parse-results-coursing.mjs",
    "parse-bzmp": "node backend/parsers/parse-results-bzmp.mjs",
    "parse-racing": "node backend/parsers/parse-results-racing.mjs",
    "load-events": "node backend/scripts/load-events.mjs",
    "load-results": "node backend/scripts/load-results.mjs",
    "ci-update-db": "node backend/scripts/ci-update-db.mjs",
    "migrate-dog-names": "node backend/scripts/migrate-normalize-dog-names.mjs",
    "sync-to-remote": "node backend/scripts/sync-local-to-remote.mjs --push"
  },
  "dependencies": {
    "better-sqlite3": "^12.11.1",
    "cheerio": "^1.0.0",
    "iconv-lite": "^0.6.3"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "wrangler": "^4.14.0"
  }
}
